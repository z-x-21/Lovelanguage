rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    match /sessions/{sessionId} {
      allow read, write: if isValidId(sessionId);

      match /setup/{setupId} {
        allow read, write: if isValidId(sessionId) && isValidId(setupId);
      }

      // get/write validan el guestId; list no tiene guestId vinculado — regla separada
      match /guests/{guestId} {
        allow get, create, update, delete: if isValidId(sessionId) && isValidId(guestId);
        allow list: if isValidId(sessionId);
      }

      match /responses/{responseId} {
        allow get, create, update, delete: if isValidId(sessionId) && isValidId(responseId);
        allow list: if isValidId(sessionId);
      }
    }
  }
}
